pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'your-docker-registry.example.com'
        IMAGE_NAME = 'magic-url-app'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    options {
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker image') {
            steps {
                ansiColor('xterm') {
                    sh "docker build -t ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Test') {
            steps {
                ansiColor('xterm') {
                    sh """
                    docker run -d -p 3000:3000 --name magicurl-test ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                    sleep 10
                    curl -f http://localhost:3000/health
                    docker rm -f magicurl-test
                    """
                }
            }
        }

        stage('Push image') {
            steps {
                ansiColor('xterm') {
                    withDockerRegistry([credentialsId: 'docker-registry-creds', url: "https://${DOCKER_REGISTRY}"]) {
                        sh "docker push ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                ansiColor('xterm') {
                    sshagent(['ec2-ssh-creds']) {
                        sh """
                        ssh -o StrictHostKeyChecking=no ubuntu@your-ec2-host << EOF
                        docker pull ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                        docker rm -f magicurl-app || true
                        docker run -d --name magicurl-app -p 80:3000 --restart unless-stopped \\
                          -e MONGO_URI='mongodb://mongo:27017/magicurl' \\
                          ${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                        EOF
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
